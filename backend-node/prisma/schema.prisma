// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// PROJECT (one disaster instance)
//////////////////////////////////////////////////////

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  googleId    String?  @unique
  designation String?
  role        String   @default("USER")
  // USER | ADMIN

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  createdProjects  Project[]        @relation("ProjectCreator")
  memberships      ProjectMember[]
  messages         Message[]
}

model ProjectMember {
  id        String   @id @default(uuid())

  projectId String
  userId    String

  role      String   @default("MEMBER")
  // MEMBER | COORDINATOR | VIEWER

  status    String   @default("PENDING")
  // PENDING | APPROVED | REJECTED

  joinedAt  DateTime?

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Project {
  id              String   @id @default(uuid())

  mobileReport  MobileReport?

  title           String?
  location        String
  latitude        Float?
  longitude       Float?
  disasterType    String?
  status          String   @default("CREATED")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inputs          Input[]
  eventSummary    EventSummary?
  chatRoom ChatRoom?
  reports         Report[]
  reconstructions Reconstruction[]
  members ProjectMember[]
  chatMessages ChatMessage[]

  creatorId String?
  creator   User? @relation("ProjectCreator", fields: [creatorId], references: [id])
}


//////////////////////////////////////////////////////
// INPUT (each uploaded file → one row)
//////////////////////////////////////////////////////

model Input {
  id            String   @id @default(uuid())
  projectId     String
  fileType      String   // image | audio | video | text | drone
  originalName  String
  s3Key         String
  s3Url         String
  analysisJson  Json?    // AI output per file
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

//////////////////////////////////////////////////////
// EVENT SUMMARY (aggregated disaster inference)
//////////////////////////////////////////////////////

model EventSummary {
  id              String   @id @default(uuid())
  projectId       String   @unique
  finalDisaster   String
  severity        String
  confidence      Float?
  summaryJson     Json     // aggregated inference + evidence
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// REPORT (TextGen output – versioned)
//////////////////////////////////////////////////////

model Report {
  id        String   @id @default(uuid())
  projectId String
  version   Int
  content   String   // generated report (text / markdown)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
}


//////////////////////////////////////////////////////
// 3D RECONSTRUCTION (SfM / MVS pipeline output)
//////////////////////////////////////////////////////

model Reconstruction {
  id            String   @id @default(uuid())
  projectId     String
  version       Int

  status        String   @default("UPLOADED")
  // UPLOADED | RUNNING | COMPLETED | FAILED

  inputCount    Int
  inputS3Prefix String   // S3 folder where ODM input images live
  outputS3Prefix String? // S3 folder where ODM outputs are stored

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedAt      DateTime?
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId])
}

//////////////////////////////////////////////////////
// MOBILE APP UPLOADS (citizen emergency reports)
//////////////////////////////////////////////////////

model MobileReport {
  id              String   @id @default(uuid())
  userId          String?
  originalName    String
  s3Key           String
  s3Url           String

  latitude        Float?
  longitude       Float?

  disasterType    String?
  severityLevel   String?
  confidence      Float?
  analysisJson    Json?

  status          String    @default("PENDING")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  projectId       String?  @unique
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  alertLogs AlertLog[]
}

//////////////////////////////////////////////////////
// ALERT LOG (authority notifications)
//////////////////////////////////////////////////////

model AlertLog {
  id               String   @id @default(uuid())
  mobileReportId   String

  authorityType    String   // POLICE | FIRE | HOSPITAL
  authorityName    String   // "Kaloor Police Station"
  phone            String?
  email            String?

  voiceStatus      String?
  smsStatus        String?
  emailStatus      String?

  acknowledged     Boolean  @default(false)
  createdAt        DateTime @default(now())

  mobileReport MobileReport @relation(fields: [mobileReportId], references: [id], onDelete: Cascade)

  @@index([mobileReportId])
}

model ChatRoom {
  id        String   @id @default(uuid())
  projectId String   @unique

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]

  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(uuid())
  chatRoomId String
  senderId   String
  content    String
  createdAt  DateTime @default(now())

  // 🔁 Reply relationship
  replyToId  String?
  replyTo    Message?  @relation("MessageReply", fields: [replyToId], references: [id])
  replies    Message[] @relation("MessageReply")

  chatRoom   ChatRoom  @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender     User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
  @@index([replyToId])
}
model ChatMessage {
  id        String   @id @default(uuid())
  projectId String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id])
}